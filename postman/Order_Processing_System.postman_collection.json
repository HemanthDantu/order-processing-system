    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order - Customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get(\"createOrderIdempotencyKey\")) {",
                  "  pm.collectionVariables.set(\"createOrderIdempotencyKey\", `order-create-${Date.now()}`);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Order created\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201]);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set(\"orderId\", response.id);",
                  "pm.collectionVariables.set(\"createdOrderStatus\", response.status);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{createOrderIdempotencyKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"keyboard-001\",\n      \"productName\": \"Mechanical Keyboard\",\n      \"quantity\": 2,\n      \"unitPrice\": 49.99\n    },\n    {\n      \"productId\": \"mouse-001\",\n      \"productName\": \"Wireless Mouse\",\n      \"quantity\": 1,\n      \"unitPrice\": 25.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "orders"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Order Retry - Same Idempotency Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Stored response is replayed\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201]);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set(\"orderId\", response.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{createOrderIdempotencyKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"keyboard-001\",\n      \"productName\": \"Mechanical Keyboard\",\n      \"quantity\": 2,\n      \"unitPrice\": 49.99\n    },\n    {\n      \"productId\": \"mouse-001\",\n      \"productName\": \"Wireless Mouse\",\n      \"quantity\": 1,\n      \"unitPrice\": 25.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "orders"
              ]
            }
          },
          "response": []
        },
